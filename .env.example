# Application Configuration
NODE_ENV=development
PORT=3000
API_VERSION=v1

# AWS Configuration
# For local development only. In production, use IAM roles (task roles, instance profiles).
AWS_REGION=ap-southeast-1
AWS_ACCESS_KEY_ID=your_access_key_here
AWS_SECRET_ACCESS_KEY=your_secret_key_here

# DynamoDB Table Names (must match CloudFormation output: share-money-{resource}-{environment})
DYNAMODB_TRIPS_TABLE=share-money-trips-dev
DYNAMODB_EXPENSES_TABLE=share-money-expenses-dev
DYNAMODB_PARTICIPANTS_TABLE=share-money-participants-dev
DYNAMODB_TRIP_MEMBERS_TABLE=share-money-trip-members-dev

# AWS Cognito Configuration
COGNITO_USER_POOL_ID=your_user_pool_id_here
COGNITO_CLIENT_ID=your_client_id_here
COGNITO_REGION=ap-southeast-1
COGNITO_ISSUER=https://cognito-idp.ap-southeast-1.amazonaws.com/your_user_pool_id_here

# S3 Configuration (for trip images)
S3_IMAGES_BUCKET=share-money-images-dev-580666963120
S3_BILLS_BUCKET=share-money-bills-dev-580666963120
S3_REGION=ap-southeast-1

# DynamoDB Images Table
DYNAMODB_IMAGES_TABLE=share-money-images-dev

# DynamoDB Bills Table
DYNAMODB_BILLS_TABLE=share-money-bills-dev

# Application Security
# ADMIN_PASSWORD is required. Must be changed to a strong value in production.
ADMIN_PASSWORD=CHANGE_ME_strong_password
# JWT_SECRET is required when Cognito is not configured (local dev only).
JWT_SECRET=your_jwt_secret_here_change_in_production
# GUEST_JWT_SECRET is required for guest invite code access.
GUEST_JWT_SECRET=your_guest_jwt_secret_here_change_in_production

# CORS Configuration (comma-separated origins; remove localhost in production)
CORS_ORIGIN=http://localhost:5173,https://your-frontend-domain.com
